# RN + native iOS builds (cocoapods, expo-updates' Metro shim, vision-camera)
# expect a flat node_modules layout. pnpm's default isolated layout breaks
# expo-updates' Metro import (`Cannot read properties of undefined (reading
# 'transformFile')`) because Metro internals aren't reachable from the
# expected nested path. hoisted matches npm/yarn behaviour.
node-linker=hoisted
