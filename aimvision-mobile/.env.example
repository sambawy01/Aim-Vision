# Runtime config consumed by `app.config.ts` and surfaced to the app via
# `Constants.expoConfig.extra.env`. Copy to `.env`, set, and export before
# `npx expo start` — or set them in `eas.json` for builds.
#
# These are NOT bundled into the JS source. They land in the Expo config at
# build/start time and are read by `src/config/env.ts`.

# Backend API base URL (FastAPI service).
API_BASE_URL=https://api.aimvision.com

# Sentry RN DSN. Leave empty to disable Sentry init.
SENTRY_DSN=

# Statsig client SDK key. Leave empty to disable feature flags.
STATSIG_CLIENT_KEY=

# OpenTelemetry OTLP endpoint. Placeholder until Sprint 6 lands the real wiring.
OTEL_ENDPOINT=
