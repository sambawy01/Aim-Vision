AIMVISION_ENV=development
AIMVISION_DATABASE_URL=postgresql+asyncpg://aimvision:aimvision@localhost:5432/aimvision
AIMVISION_AUDIT_DATABASE_URL=postgresql+asyncpg://audit_writer:audit_writer@localhost:5432/aimvision_audit
AIMVISION_JWT_SECRET=change-me-in-production-32bytes-minimum-key
AIMVISION_JWT_ALG=HS256
AIMVISION_JWT_TTL_SECONDS=3600
AIMVISION_GIT_SHA=dev
AIMVISION_VERSION=0.1.0
AIMVISION_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
AIMVISION_IP_HASH_SALT=daily-rotated-salt-replace-me

# Identity provider (ADR-0010). "stub" = built-in PBKDF2+HS256 (today's
# path). "gotrue" = self-hosted Supabase Auth. The verifier ships in this
# release; the /auth/login integration that consumes a GoTrue token lands
# in a follow-up PR.
AIMVISION_AUTH_PROVIDER=stub
# Required when AUTH_PROVIDER=gotrue. Must match GOTRUE_JWT_ISS in your
# GoTrue deployment. Typical self-host: http(s)://<gotrue-host>/auth/v1
# AIMVISION_GOTRUE_ISSUER=https://gotrue.aimvision.local/auth/v1
AIMVISION_GOTRUE_AUDIENCE=authenticated
# HS256 path: same secret as GOTRUE_JWT_SECRET on the GoTrue side.
# AIMVISION_GOTRUE_JWT_ALG=HS256
# AIMVISION_GOTRUE_JWT_SECRET=share-this-string-with-the-gotrue-process
# RS256 path: pinned PEM public key. Set _ALG to RS256 and supply the PEM.
# AIMVISION_GOTRUE_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n..."

